          "format": "time_series",
          "rawSql": "SELECT \n  DATE(started_date) as time,\n  SUM(time_spent_minutes)/60 as hours\nFROM issue_worklogs\nWHERE id LIKE 'tempo:%' \n  AND started_date IS NOT NULL\n  AND $__timeFilter(started_date)\n  AND author_id IN ($author)\nGROUP BY DATE(started_date)\nORDER BY time",
          "refId": "A"
        }
      ],
