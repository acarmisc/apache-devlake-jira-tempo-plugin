            "type": "mysql",
            "uid": "${datasource}"
          },
          "format": "table",
          "rawSql": "SELECT \n  t.name as team,\n  SUM(w.time_spent_minutes)/60 as hours\nFROM _tool_tempo_worklogs w\nJOIN _tool_tempo_teams t ON w.team_id = t.team_id AND w.connection_id = t.connection_id\nWHERE $__timeFilter(w.created_at)\n  AND w.connection_id IN ($connection_id)\n  AND t.name IN ($team)\nGROUP BY t.name\nORDER BY hours DESC",
          "refId": "A"
        }
      ],
      "title": "Ore per Team",
      "type": "barchart"
    },
